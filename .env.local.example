# ── Market Data ───────────────────────────────────────────────────────────────
# Polygon.io API key – https://polygon.io/dashboard/api-keys
POLYGON_API_KEY=your_polygon_api_key_here

# Financial Modeling Prep API key – https://financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_api_key_here

# ── AI Enhancement (optional) ────────────────────────────────────────────────
# Anthropic Claude API key – https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Supabase (required for accuracy dashboard & cron jobs) ───────────────────
# Project URL and anon/public key – https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service-role key (server-side only, bypasses RLS – keep secret)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Cron Job Security ─────────────────────────────────────────────────────────
# Secret Vercel sends as "Authorization: Bearer <value>" on cron invocations.
# Set this in your Vercel project environment variables as well.
# Generate a strong random value: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here
